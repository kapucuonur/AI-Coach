[Unit]
Description=BikeFit AI Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/bikefit/backend
ExecStart=/home/pi/bikefit/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5
EnvironmentFile=/home/pi/bikefit/backend/.env

[Install]
WantedBy=multi-user.target
