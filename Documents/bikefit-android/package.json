{
  "name": "bikefit-android",
  "version": "1.0.0",
  "description": "BikeFit AI - Android app powered by Capacitor",
  "main": "index.js",
  "scripts": {
    "copy-web": "cp -R ../bikefit/frontend/* ./www/",
    "build": "echo 'No build step needed - static web app'",
    "sync": "npm run copy-web && npx cap sync android",
    "open": "npx cap open android"
  },
  "keywords": [
    "bikefit",
    "cycling",
    "ai",
    "android",
    "capacitor"
  ],
  "author": "Onur Kapucu <onur@trihonor.com>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor/android": "^8.3.4",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5"
  }
}
